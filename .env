# ===========================================
# n8n + PostgreSQL Podman Configuration
# ===========================================

# PostgreSQL Configuration
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_password
POSTGRES_DB=n8n

# n8n Configuration
N8N_PORT=15678
N8N_HOST=0.0.0.0
N8N_PROTOCOL=http

# Webhook URL (update this for Cloudflare Tunnel)
WEBHOOK_URL=http://192.168.50.86:15678/

# Timezone
GENERIC_TIMEZONE=Asia/Taipei
